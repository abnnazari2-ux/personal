{
  "name": "basit-health-command",
  "version": "1.0.0",
  "description": "Personal health tracker for Basit Nazari — Kabul, Afghanistan",
  "main": "server/index.js",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
